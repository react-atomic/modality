{
  "version": "0.0.1",
  "name": "modality-cli-kit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/react-atomic/modality"
  },
  "homepage": "https://github.com/react-atomic/modality",
  "description": "TODO: description",
  "keywords": [
    "modality-cli-kit"
  ],
  "author": "Hill <hill@kimo.com>",
  "license": "ISC",
  "git.addAICoAuthor": "off",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "modality-bun-kit": "*"
  },
  "exports": {
    "types": "./dist/types/index.d.ts",
    "require": "./build/cjs/src/index.js",
    "import": "./build/es/src/index.mjs"
  },
  "types": "./dist/types/index.d.ts",
  "main": "./build/cjs/src/index.js",
  "module": "./build/es/src/index.mjs",
  "bin": {
    "modality-cli-kit": "src/cli.ts"
  },
  "scripts": {
    "build:types": "bun tsc -p ./",
    "build": "bun run build:types && bun run build:cli",
    "test": "npm run build && bun test",
    "build:cjs": "bun build ./src/index.ts --target=bun --outdir=./build/cjs --format=cjs",
    "build:esm": "bun build ./src/index.ts --target=bun --outdir=./build/es --format=esm",
    "build:cli": "mkdir -p build/cjs/src build/es/src && bun build ./src/index.ts --target=bun --outdir=./build/cjs --format=cjs && bun build ./src/index.ts --target=bun --outdir=./build/es --format=esm && cp build/cjs/index.js build/cjs/src/index.js && cp build/es/index.js build/es/src/index.mjs"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ]
}
